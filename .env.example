# 🦞 OpenClaw + Ollama - Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ==================== OPENCLAW ====================

# Gemini API (Google)
GEMINI_API_KEY=sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter API (proxy de múltiplos modelos)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ==================== SYSTEM ====================

# Timezone
TZ=America/Sao_Paulo

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Home directory do OpenClaw
OPENCLAW_HOME=/home/openclaw/.config/openclaw

# ==================== DOCKER ====================

# Porta OpenClaw (externo)
OPENCLAW_PORT=18790

# Porta Nginx (HTTP)
NGINX_HTTP_PORT=80

# Porta Nginx (HTTPS)
NGINX_HTTPS_PORT=443

# ==================== SEGURANÇA ====================

# Token de acesso OpenClaw (gerado automaticamente)
# Deixe vazio para gerar novo
OPENCLAW_TOKEN=

# Modo de bind do Gateway
# loopback: localhost only (padrão, seguro)
# lan: acessível na rede local
# 0.0.0.0: acessível remotamente (CUIDADO!)
GATEWAY_BIND=loopback

# Requer pairing para novos dispositivos?
# true: Requer código de pairing
# false: Aceita automático (use com cuidado!)
# Alterar para false para entrar direto sem o código de pareamento
PAIRING_REQUIRED=true

# ==================== STORAGE ====================

# Diretório de dados
DATA_VOLUME=./data

# Diretório de logs
LOGS_VOLUME=./logs

# ==================== AMBIENTE ====================

# Modo de execução
# development: Mais logs, sem otimizações
# production: Otimizado, menos logs
ENVIRONMENT=development

# ==================== INSTRUÇÕES ====================

# 1. Copiar este arquivo:
#    cp .env.example .env

# 2. Preencher com seus valores (especialmente keys de API)

# 3. Usar com docker-compose:
#    docker-compose --env-file .env up -d

# 4. Validar configuração:
#    docker-compose config

# ==================== NOTAS ====================

# - Chaves de API: NUNCA commitar o .env em git
# - Adicione .env ao .gitignore
# - Para desenvolvimento local: use os valores padrão
# - Para produção: use gerenciador de secrets (HashiCorp Vault, etc)
# - Mais segurança: use docker-compose.prod.yml separado

# ==================== VARIÁVEIS DINÂMICAS ====================

# Estas são setadas automaticamente (não edite):
# COMPOSE_PROJECT_NAME=openclaw-docker
# DOCKER_BUILDKIT=1
# COMPOSE_DOCKER_CLI_BUILD=1
